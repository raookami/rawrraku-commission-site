# Copy file ini jadi .env lalu isi nilainya
REACT_APP_SUPABASE_URL=your_supabase_url_here
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Nama admin (huruf kecil semua)
REACT_APP_ADMIN_NAME=your_name_here
# Password untuk masuk mode admin
REACT_APP_ADMIN_PASSWORD=your_password_here

# Cloudinary — untuk upload foto portfolio
# Cloud name bisa dilihat di dashboard Cloudinary (pojok kiri atas)
REACT_APP_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
# Upload preset: Cloudinary dashboard → Settings → Upload → Upload presets → buat baru (mode: Unsigned)
REACT_APP_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here
